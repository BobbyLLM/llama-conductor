{
  "manifest_version": 2,
  "name": "MoA Chat Bridge",
  "version": "1.0.7",
  "description": "Send selected text to llama-conductor chat sidebar without triggering ?q= double-submission.",
  "browser_specific_settings": {
    "gecko": {
      "id": "moa-chat-bridge@llama-conductor",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "*://127.0.0.1/*"
  ],
  "sidebar_action": {
    "default_title": "MoA Chat",
    "default_panel": "sidebar.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://127.0.0.1/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
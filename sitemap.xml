---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/about/</loc>
  </url>
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/blog/</loc>
  </url>
{% for p in site.pages %}
{% if p.url contains '/blog/' and p.url != '/blog/' and p.url != '/blog/index.html' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ p.url | replace: 'index.html','' }}</loc>
  </url>
{% endif %}
{% endfor %}
</urlset>

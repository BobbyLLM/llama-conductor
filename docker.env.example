# docker.env.example
# Copy to .env (same folder as docker-compose.yml) and edit as needed.

# Router image tag if you prefer prebuilt image over local build.
# ROUTER_IMAGE=ghcr.io/bobbyllm/llama-conductor:latest

# Router/API ports
ROUTER_PORT=9000
SHIM_PORT=8088

# Qdrant
QDRANT_PORT=6333

# Open WebUI
WEBUI_PORT=3000

# Ollama
OLLAMA_PORT=11434
